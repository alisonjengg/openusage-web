# Copy to .env.local and fill in. NEVER commit the real .env.local.

# The single password used to log into the dashboard.
APP_PASSWORD=

# 32-byte key (hex = 64 chars) used to encrypt stored tokens and sign the
# session cookie. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
APP_SECRET=

# SQLite database file path (created automatically).
DATABASE_PATH=./data/openusage.db

# Normal usage cache TTL in seconds. Floored at 60.
USAGE_CACHE_TTL_SECONDS=60

# Set to 1 only when a trusted reverse proxy overwrites X-Forwarded-* headers.
TRUST_PROXY=0
